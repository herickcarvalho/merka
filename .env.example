# Copie este arquivo para ".env" na raiz do projeto e ajuste os valores conforme o ambiente.
# Nunca commitar o arquivo ".env" real (já está no .gitignore).

# ---------- PostgreSQL ----------
POSTGRES_DB=mercado_erp
POSTGRES_USER=mercado_user
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# ---------- Backend (Mercado.Api) ----------
ASPNETCORE_ENVIRONMENT=Development
API_HTTP_PORT=5000
API_HTTPS_PORT=5001
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=mercado_erp;Username=mercado_user;Password=change_me

# ---------- Frontend (Vite) ----------
VITE_API_BASE_URL=http://localhost:5000/api
FRONTEND_PORT=5173
